{% comment %}
  ============================================================
  Section: Custom Product Grid
  Description: Shoppable image grid where each photo displays a
               "+" hotspot. Clicking it opens a product popup
               with dynamic variant selectors and AJAX Add to Cart.
  ============================================================
{% endcomment %}

<style>
.custom-product-grid {
    padding-top: 32px;
    padding-bottom: 32px;
}

.custom-product-grid [hidden] { display: none !important; }

/* ── Section heading ── */
.custom-product-grid__heading {
  font-family: "Lustria", serif;
  font-size: 36px;
  line-height: 1.2;
  font-weight: 400;
  letter-spacing: 0;
  margin-bottom: 20px;
}

/* ── 3-column grid ── */
.custom-product-grid__grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16px;
}

/* ── Card cell ── */
.custom-product-grid__item { position: relative; }

.custom-product-grid__photo {
  position: relative;
  width: 100%;
  padding-bottom: 110%;
  background-color: #f5f5f5;
  background-size: cover;
  background-position: center;
  overflow: hidden;
}

.custom-product-grid__photo--placeholder::after {
  content: '';
  position: absolute;
  inset: 0;
  background: repeating-linear-gradient(
    45deg,
    #dddddd 0px, #dddddd 10px,
    #eeeeee 10px, #eeeeee 20px
  );
}

/* ── Quick add to cart "+" button ── */
.custom-product-grid__hotspot {
  position: absolute;
  bottom: 16px;
  right: 16px;
  width: 22px;
  height: 22px;
  border-radius: 50%;
  border: 1px solid #F8F8F8E5;
  background: #F8F8F8E5;
  opacity: 0.9;
  backdrop-filter: blur(4px);
  -webkit-backdrop-filter: blur(4px);
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background .2s, transform .2s;
  z-index: 2;
}

.custom-product-grid__hotspot:hover,
.custom-product-grid__hotspot:focus-visible {
  background: rgba(255, 255, 255, 0.7);
  transform: scale(1.1);
  outline: none;
}

.custom-product-grid__hotspot-icon {
  font-size: 18px;
  line-height: 1;
  color: #000;
  font-weight: 300;
  pointer-events: none;
  user-select: none;
}

/* ── Overlay backdrop ── */
.custom-product-grid__overlay {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.7);
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16px;
  opacity: 0;
  visibility: hidden;
  pointer-events: none;
  transition: opacity .2s, visibility .2s;
}

.custom-product-grid__overlay[aria-hidden="false"] {
  opacity: 1 !important;
  visibility: visible !important;
  pointer-events: auto !important;
}

/* ── Popup card ── */
.custom-product-grid__popup {
  position: relative;
  background: #fff;
  width: 100%;
  max-width: 460px;
  max-height: 90vh;
  overflow-y: auto;
  padding: 32px 28px 28px;
  box-shadow: 0 2px 4px 0 rgba(0, 0, 0, 0.2);
  transform: translateY(12px);
  transition: transform .2s;
}

.custom-product-grid__overlay[aria-hidden="false"] .custom-product-grid__popup {
  transform: translateY(0);
}

/* Close button */
.custom-product-grid__close {
  position: absolute;
  top: 14px;
  right: 16px;
  background: none;
  border: none;
  line-height: 1;
  cursor: pointer;
  padding: 4px 6px;
  transition: opacity .2s;
}

.custom-product-grid__close:hover { 
  opacity: 0.6;
 }

.custom-product-grid__close img   { 
  display: block; 
  width: 16px; 
  height: 16px; 
}

/* ── Loading spinner ── */
.custom-product-grid__loader {
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 160px;
}

.custom-product-grid__spinner {
  width: 28px;
  height: 28px;
  border: 3px solid #e0e0e0;
  border-top-color: #fff;
  border-radius: 50%;
  animation: cpg-spin 0.7s linear infinite;
}

@keyframes cpg-spin { 
  to { 
    transform: rotate(360deg); 
  } 
}

/* ── Popup top row ── */
.custom-product-grid__popup-top {
  display: flex;
  align-items: flex-end;
  gap: 20px;
  margin-bottom: 22px;
}

.custom-product-grid__popup-img {
  width: 120px;
  height: auto;
  object-fit: cover;
  flex-shrink: 0;
  background: #f5f5f5;
}

.custom-product-grid__popup-meta { flex: 1; }

.custom-product-grid__popup-title {
  font-size: 16px;
  font-weight: 300;
  line-height: 1.2;
  margin-bottom: 24px;
}

.custom-product-grid__popup-price {
  font-size: 16px;
  font-weight: 400;
  line-height: 1.2;
  margin-bottom: 16px;
}

.custom-product-grid__popup-desc {
  font-size: 14px;
  font-weight: 300;
  color: #000;
  line-height: 1.15;
}

/* ── Variant groups ── */
.custom-product-grid__variant-group { margin-bottom: 18px; }

.custom-product-grid__variant-label {
  display: block;
  font-size: 14px;
  line-height: 1.3;
  text-transform: uppercase;
  letter-spacing: 0;
  margin-bottom: 8px;
  color: #333;
}

/* ── Color swatches ── */
.custom-product-grid__swatches {
  display: flex;
  border: 1px solid #e0e0e0;
  overflow: hidden;
}

.custom-product-grid__swatch {
  flex: 1;
  padding: 10px 12px;
  text-align: center;
  font-size: 14px;
  font-weight: 400;
  line-height: 1.3;
  cursor: pointer;
  background: #fff;
  color: #000;
  border: none;
  border-left: 3px solid var(--cpg-swatch-color, #000);
  border-right: 1px solid #e0e0e0;
  transition: background .2s, color .2s;
}

.custom-product-grid__swatch:last-child { border-right: none; }

.custom-product-grid__swatch[aria-pressed="true"] {
  background: #000;
  color: #fff;
  font-weight: 500;
}

.custom-product-grid__swatch:disabled { opacity: 0.4; cursor: not-allowed; }

/* ── Size select ── */
.custom-product-grid__size-select-wrap {
  position: relative;
  border: 1px solid #e0e0e0;
  overflow: hidden;
}

.custom-product-grid__size-select {
  appearance: none;
  -webkit-appearance: none;
  width: 100%;
  padding: 12px 40px 12px 14px;
  font-size: 16px;
  line-height: 1;
  border: none;
  background: #fff;
  cursor: pointer;
  color: #000;
  outline: none;
}
.custom-product-grid__size-caret {
  pointer-events: none;
  position: absolute;
  right: 14px;
  top: 50%;
  transform: translateY(-50%);
  line-height: 1;
  color: #000;
}

/* ── Feedback message ── */
.custom-product-grid__feedback {
  font-size: 12px;
  margin-bottom: 12px;
  padding: 8px 12px;
  border-radius: 4px;
  background: #f0fdf0;
  color: #166534;
  border: 1px solid #bbf7d0;
}
.custom-product-grid__feedback--error {
  background: #fff1f2;
  color: #9f1239;
  border-color: #fecdd3;
}

/* ── Add to Cart button ── */
.custom-product-grid__atc {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 28px;
  width: 100%;
  padding: 10.5px 36px;
  background: #000;
  color: #fff;
  border: none;
  font-size: 16px;
  font-weight: 400;
  letter-spacing: 0;
  text-transform: uppercase;
  cursor: pointer;
  margin-top: 4px;
  overflow: hidden;
  transition: background .2s;
}

.custom-product-grid__atc-arrow {
  display: inline-flex;
  align-items: center;
  transition: transform .2s;
}

.custom-product-grid__atc:hover:not(:disabled) .custom-product-grid__atc-arrow {
  transform: translateX(5px);
}

.custom-product-grid__atc:disabled  { 
  opacity: 0.5; 
  cursor: not-allowed; 
}

.custom-product-grid__atc:not(:disabled):hover { background: #333; }

.custom-product-grid__atc--loading .custom-product-grid__atc-label,
.custom-product-grid__atc--loading .custom-product-grid__atc-arrow { opacity: 0; }

.custom-product-grid__atc--loading::after {
  content: '';
  position: absolute;
  width: 16px;
  height: 16px;
  border: 2px solid rgba(255, 255, 255, 0.4);
  border-top-color: #fff;
  border-radius: 50%;
  animation: cpg-spin 0.7s linear infinite;
}

/* Dawn: prevent empty-cart state persisting after first add-to-cart */
cart-drawer.active:not(.is-empty) .drawer__inner-empty { display: none !important; }

/* ── Responsive ── */
@media (max-width: 767px) {
  .custom-product-grid__grid { grid-template-columns: repeat(2, 1fr); }

  .custom-product-grid__heading {
    font-size: 24px;
    text-align: center;
  }
}

@media (max-width: 479px) {
  .custom-product-grid { 
    padding: 24px 16px 40px; 
  }

  .custom-product-grid__grid { 
    grid-template-columns: 1fr 1fr; 
    gap: 8px; 
  }

  .custom-product-grid__popup { 
    padding: 28px 18px 20px; 
  }

  .custom-product-grid__popup-img { 
    width: 80px; 
    height: 80px; 
  }

  .custom-product-grid__popup-title { 
    font-size: 0.9rem; 
  }
}

</style>

{%- liquid
  assign section_id = section.id
  assign heading    = section.settings.heading
-%}

<div
  class="custom-product-grid page-width"
  id="custom-product-grid-{{ section_id }}"
  data-section-id="{{ section_id }}"
  aria-label="{{ heading | escape }}"
>

  {%- if heading != blank -%}
    <h2 class="custom-product-grid__heading">{{ heading }}</h2>
  {%- endif -%}

  <div class="custom-product-grid__grid" role="list">
    {%- for block in section.blocks -%}
      {%- liquid
        assign block_product = block.settings.product
        assign block_image   = block.settings.image
      -%}
      <div
        class="custom-product-grid__item"
        role="listitem"
        {{ block.shopify_attributes }}
      >
        {%- if block_image != blank -%}
          {%- assign bg_src = block_image | image_url: width: 800 -%}
        {%- elsif block_product != blank -%}
          {%- assign bg_src = block_product.featured_image | image_url: width: 800 -%}
        {%- else -%}
          {%- assign bg_src = blank -%}
        {%- endif -%}

        <div
          class="custom-product-grid__photo{% if bg_src == blank %} custom-product-grid__photo--placeholder{% endif %}"
          {% if bg_src != blank %}style="background-image: url('{{ bg_src }}')"{% endif %}
        >
          {%- if block_product != blank -%}
            <button
              class="custom-product-grid__hotspot"
              type="button"
              aria-label="Quick view {{ block_product.title | escape }}"
              aria-haspopup="dialog"
              data-product-url="/products/{{ block_product.handle | escape }}.js"
            >
              <span class="custom-product-grid__hotspot-icon" aria-hidden="true">+</span>
            </button>
          {%- endif -%}
        </div>
      </div>
    {%- endfor -%}
  </div>

  {%- comment %} Shared popup — JS populates it per product {%- endcomment %}
  <div
    class="custom-product-grid__overlay"
    id="custom-product-grid-overlay-{{ section_id }}"
    role="dialog"
    aria-modal="true"
    aria-label="Product quick view"
    aria-hidden="true"
    tabindex="-1"
    style="opacity:0;visibility:hidden;pointer-events:none;"
  >
    <div class="custom-product-grid__popup">

      <button class="custom-product-grid__close" type="button" aria-label="Close quick view" data-close>
        <img
            src="{{ 'custom-icon-close.svg' | asset_url }}"
            alt="close icon"
            width="16"
        >
      </button>

      <div class="custom-product-grid__popup-body" aria-live="polite">

        <div class="custom-product-grid__loader" aria-label="Loading product...">
          <span class="custom-product-grid__spinner" aria-hidden="true"></span>
        </div>

        <div class="custom-product-grid__popup-content" hidden>

          <div class="custom-product-grid__popup-top">
            <img
              class="custom-product-grid__popup-img"
              src="" alt=""
              width="160" height="160"
              loading="lazy"
            >
            <div class="custom-product-grid__popup-meta">
              <p class="custom-product-grid__popup-title"></p>
              <p class="custom-product-grid__popup-price"></p>
              <p class="custom-product-grid__popup-desc"></p>
            </div>
          </div>

          <div class="custom-product-grid__variants"></div>

          <p class="custom-product-grid__feedback" role="status" aria-live="polite" hidden></p>

          <button class="custom-product-grid__atc" type="button" disabled aria-disabled="true" data-atc>
            <span class="custom-product-grid__atc-label">ADD TO CART</span>
            <span class="custom-product-grid__atc-arrow" aria-hidden="true">
              <img
                src="{{ 'icon-arrow-right-white.svg' | asset_url }}"
                alt="right arrow"
                width="25"
                height="25"
              >
            </span>
          </button> 
        </div>
      </div>
    </div>
  </div>

</div>

<script>
(function () {
  'use strict';

  /* ── DOM references ── */
  const SECTION_ID  = '{{ section_id }}';
  const SECTION_EL  = document.getElementById('custom-product-grid-' + SECTION_ID);
  const OVERLAY     = document.getElementById('custom-product-grid-overlay-' + SECTION_ID);
  const LOADER      = OVERLAY.querySelector('.custom-product-grid__loader');
  const CONTENT     = OVERLAY.querySelector('.custom-product-grid__popup-content');
  const IMG_EL      = OVERLAY.querySelector('.custom-product-grid__popup-img');
  const TITLE_EL    = OVERLAY.querySelector('.custom-product-grid__popup-title');
  const PRICE_EL    = OVERLAY.querySelector('.custom-product-grid__popup-price');
  const DESC_EL     = OVERLAY.querySelector('.custom-product-grid__popup-desc');
  const VARIANTS_EL = OVERLAY.querySelector('.custom-product-grid__variants');
  const FEEDBACK_EL = OVERLAY.querySelector('.custom-product-grid__feedback');
  const ATC_BTN     = OVERLAY.querySelector('[data-atc]');
  const CLOSE_BTN   = OVERLAY.querySelector('[data-close]');


  /* ── State ── */
  const state = {
    product:         null,
    selectedOptions: {},
  };

  /* ── Colour map for swatch left-border strips ── */
  const COLOR_MAP = {
    white:  '#ffffff', black:  '#111111', blue:   '#2563eb',
    navy:   '#1e3a5f', red:    '#dc2626', green:  '#16a34a',
    grey:   '#9ca3af', gray:   '#9ca3af', yellow: '#facc15',
    orange: '#f97316', pink:   '#ec4899', purple: '#9333ea',
    brown:  '#92400e', beige:  '#d4b896', cream:  '#fffdd0',
    silver: '#c0c0c0', gold:   '#ffd700',
  };

  function resolveSwatchColor(name) {
    return COLOR_MAP[name.toLowerCase().trim()] || '#111111';
  }

  /* ────────────────────────────────────────────────────────
     HELPERS
  ──────────────────────────────────────────────────────── */

  function formatPrice(cents) {
    return (cents / 100).toLocaleString('en-EU', {
      style:                 'currency',
      currency:              window.Shopify?.currency?.active ?? 'EUR',
      minimumFractionDigits: 2,
    });
  }

  async function cartPost(endpoint, payload) {
    const res = await fetch(endpoint, {
      method:  'POST',
      headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
      body:    JSON.stringify(payload),
    });
    if (!res.ok) {
      const err = await res.json().catch(() => ({}));
      throw new Error(err.description || 'Cart error');
    }
    return res.json();
  }

  function findMatchingVariant() {
    if (!state.product) return null;
    return state.product.variants.find((v) =>
      v.options.every((val, idx) =>
        state.selectedOptions[state.product.options[idx]] === val
      )
    ) ?? null;
  }

  /* ────────────────────────────────────────────────────────
     POPUP OPEN / CLOSE
  ──────────────────────────────────────────────────────── */

  function openPopup(productUrl) {
    LOADER.hidden         = false;
    CONTENT.hidden        = true;
    hideFeedback();
    setAtcEnabled(false);

    OVERLAY.setAttribute('aria-hidden', 'false');
    CLOSE_BTN.focus();
    document.body.style.overflow = 'hidden';

    loadProduct(productUrl);
  }

  function closePopup() {
    OVERLAY.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
    state.product         = null;
    state.selectedOptions = {};
  }

  /* ────────────────────────────────────────────────────────
     PRODUCT LOADING
  ──────────────────────────────────────────────────────── */

  async function loadProduct(productUrl) {
    try {
      const res = await fetch(productUrl, { headers: { 'Accept': 'application/json' } });
      if (!res.ok) throw new Error('Product not found');
      const product = await res.json();

      product.options = product.options.map((o) =>
        typeof o === 'object' && o !== null ? o.name : o
      );

      if (product.featured_image && typeof product.featured_image === 'object') {
        product.featured_image = product.featured_image.src ?? '';
      }

      state.product = product;

      const firstVar = product.variants.find((v) => v.available) ?? product.variants[0];
      product.options.forEach((name, idx) => {
        state.selectedOptions[name] = firstVar?.options[idx] ?? '';
      });

      renderProduct(product);

    } catch (err) {
      console.error('[CPG] loadProduct failed:', productUrl, err);
      showFeedback('Could not load product. Please try again.', true);
      LOADER.hidden  = true;
      CONTENT.hidden = false;
    }
  }

  /* ────────────────────────────────────────────────────────
     RENDER
  ──────────────────────────────────────────────────────── */

  function renderProduct(product) {
    TITLE_EL.textContent = product.title;

    const imgSrc = product.featured_image ?? '';
    IMG_EL.src   = imgSrc
      ? imgSrc.replace(/(\.(jpg|jpeg|png|gif|webp))/, '_300x300$1')
      : '';
    IMG_EL.alt = product.title;

    const variant        = findMatchingVariant();
    PRICE_EL.textContent = variant ? formatPrice(variant.price) : '';

    const tmp           = document.createElement('div');
    tmp.innerHTML       = product.body_html || product.description || '';
    DESC_EL.textContent = tmp.textContent.trim();

    renderVariants(product);

    LOADER.hidden  = true;
    CONTENT.hidden = false;

    updateAtcState();
  }

  /**
   * Sort options colour-first, size-second, preserving original index
   * so availability lookups remain correct without using fragile indexOf.
   */
  function renderVariants(product) {
    VARIANTS_EL.innerHTML = '';

    const sortedOptions = product.options
      .map((name, idx) => ({ name, idx }))
      .sort((a, b) => {
        const rank = (s) => /colou?r/i.test(s) ? 0 : /size/i.test(s) ? 1 : 2;
        return rank(a.name) - rank(b.name);
      });

    sortedOptions.forEach(({ name: optName, idx: optIndex }) => {
      const uniqueVals = [...new Set(product.variants.map((v) => v.options[optIndex]))];

      const group = document.createElement('div');
      group.className = 'custom-product-grid__variant-group';

      const label = document.createElement('span');
      label.className   = 'custom-product-grid__variant-label';
      label.textContent = optName;
      group.appendChild(label);

      group.appendChild(
        /colou?r/i.test(optName)
          ? buildSwatches(optName, optIndex, uniqueVals, product)
          : buildSizeSelect(optName, optIndex, uniqueVals, product)
      );

      VARIANTS_EL.appendChild(group);
    });
  }

  function buildSwatches(optName, optIndex, values, product) {
    const wrap = document.createElement('div');
    wrap.className = 'custom-product-grid__swatches';
    wrap.setAttribute('role', 'group');
    wrap.setAttribute('aria-label', optName + ' options');

    /* Build availability set once — O(n) instead of O(n×m) */
    const availableVals = new Set(
      product.variants
        .filter((v) => v.available)
        .map((v) => v.options[optIndex])
    );

    values.forEach((val) => {
      const btn = document.createElement('button');
      btn.type           = 'button';
      btn.className      = 'custom-product-grid__swatch';
      btn.textContent    = val;
      btn.dataset.option = optName;
      btn.dataset.value  = val;
      btn.style.setProperty('--cpg-swatch-color', resolveSwatchColor(val));
      btn.setAttribute('aria-pressed', String(state.selectedOptions[optName] === val));
      btn.disabled = !availableVals.has(val);
      btn.addEventListener('click', onSwatchClick);
      wrap.appendChild(btn);
    });

    return wrap;
  }

  function buildSizeSelect(optName, optIndex, values, product) {
    const wrap = document.createElement('div');
    wrap.className = 'custom-product-grid__size-select-wrap';

    const sel = document.createElement('select');
    sel.className      = 'custom-product-grid__size-select';
    sel.dataset.option = optName;
    sel.setAttribute('aria-label', optName);

    const placeholder       = document.createElement('option');
    placeholder.value       = '';
    placeholder.textContent = 'Choose your ' + optName.toLowerCase();
    placeholder.disabled    = true;
    placeholder.selected    = !state.selectedOptions[optName];
    sel.appendChild(placeholder);

    /* Build availability set once — O(n) instead of O(n×m) */
    const availableVals = new Set(
      product.variants
        .filter((v) => v.available)
        .map((v) => v.options[optIndex])
    );

    values.forEach((val) => {
      const opt       = document.createElement('option');
      opt.value       = val;
      opt.textContent = val;
      opt.disabled    = !availableVals.has(val);
      if (state.selectedOptions[optName] === val) opt.selected = true;
      sel.appendChild(opt);
    });

    sel.addEventListener('change', onSelectChange);

    const caret = document.createElement('span');
    caret.className = 'custom-product-grid__size-caret';
    caret.setAttribute('aria-hidden', 'true');

    caret.innerHTML = `<img
            src="{{ 'custom-icon-caret.svg' | asset_url }}"
            alt=""
            width="16"
            height="16"
          >`;

    wrap.appendChild(sel);
    wrap.appendChild(caret);
    return wrap;
  }

  /* ────────────────────────────────────────────────────────
     OPTION CHANGE HANDLERS
  ──────────────────────────────────────────────────────── */

  function onSwatchClick(e) {
    const btn     = e.currentTarget;
    const optName = btn.dataset.option;

    state.selectedOptions[optName] = btn.dataset.value;

    btn.closest('.custom-product-grid__swatches')
       .querySelectorAll('.custom-product-grid__swatch')
       .forEach((s) => s.setAttribute('aria-pressed', String(s === btn)));

    afterOptionChange();
  }

  function onSelectChange(e) {
    const sel = e.currentTarget;
    state.selectedOptions[sel.dataset.option] = sel.value;
    afterOptionChange();
  }

  function afterOptionChange() {
    hideFeedback();
    const variant        = findMatchingVariant();
    PRICE_EL.textContent = variant ? formatPrice(variant.price) : '';
    updateAtcState();
  }

  /* ────────────────────────────────────────────────────────
     ADD TO CART
  ──────────────────────────────────────────────────────── */

  function setAtcEnabled(enabled) {
    ATC_BTN.disabled = !enabled;
    ATC_BTN.setAttribute('aria-disabled', String(!enabled));
  }

  function updateAtcState() {
    const variant = findMatchingVariant();
    setAtcEnabled(!!(variant?.available));
  }

  async function onAtcClick() {
    const variant = findMatchingVariant();
    if (!variant?.available) return;

    ATC_BTN.classList.add('custom-product-grid__atc--loading');
    setAtcEnabled(false);
    hideFeedback();

    try {
      await cartPost('/cart/add.js', { items: [{ id: variant.id, quantity: 1 }] });

      const openerRef = ATC_BTN;
      closePopup();
      refreshCartUI(openerRef);

    } catch (err) {
      showFeedback(err.message || 'Could not add to cart. Please try again.', true);
      setAtcEnabled(true);
      /* Prevent rapid double-clicks on error only */
      setTimeout(() => setAtcEnabled(true), 800);
    } finally {
      ATC_BTN.classList.remove('custom-product-grid__atc--loading');
    }
  }

  /* ────────────────────────────────────────────────────────
     CART UI REFRESH — Dawn theme compatible
     Always uses manual DOM patching — more reliable than
     calling renderContents() with raw HTML strings.
  ──────────────────────────────────────────────────────── */

  function refreshCartUI(openerEl) {
    const cartDrawer       = document.querySelector('cart-drawer');
    const cartNotification = document.querySelector('cart-notification');

    Promise.all([
      fetch('/?section_id=cart-drawer').then((r) => r.text()),
      fetch('/?section_id=cart-icon-bubble').then((r) => r.text()),
    ])
      .then(([drawerHTML, bubbleHTML]) => {
        const drawerDoc = new DOMParser().parseFromString(drawerHTML, 'text/html');
        const bubbleDoc = new DOMParser().parseFromString(bubbleHTML, 'text/html');

        /* Patch line items, footer total, and checkout button */
        ['cart-drawer-items', '.cart-drawer__footer', '.cart__ctas'].forEach((sel) => {
          const target = document.querySelector(sel);
          const source = drawerDoc.querySelector(sel);
          if (target && source) target.replaceWith(source);
        });

        /* Patch header icon count */
        const bubbleTarget = document.getElementById('cart-icon-bubble');
        const bubbleSource = bubbleDoc.querySelector('.shopify-section');
        if (bubbleTarget && bubbleSource) bubbleTarget.innerHTML = bubbleSource.innerHTML;

        const cartEl = cartNotification ?? cartDrawer;
        if (cartEl) {
          cartEl.classList.remove('is-empty');
          if (typeof cartEl.setActiveElement === 'function') cartEl.setActiveElement(openerEl);
          if (typeof cartEl.open === 'function')      cartEl.open(openerEl);
          else if (typeof cartEl.show === 'function') cartEl.show(openerEl);
        }
      })
      .catch((err) => {
        console.error('[CPG] cart refresh failed:', err);
        if (cartDrawer) {
          cartDrawer.classList.remove('is-empty');
          if (typeof cartDrawer.open === 'function') cartDrawer.open(openerEl);
        }
      });
  }

  /* ────────────────────────────────────────────────────────
     FEEDBACK
  ──────────────────────────────────────────────────────── */

  function showFeedback(message, isError = false) {
    FEEDBACK_EL.textContent = message;
    FEEDBACK_EL.classList.toggle('custom-product-grid__feedback--error', isError);
    FEEDBACK_EL.hidden = false;
  }

  function hideFeedback() {
    FEEDBACK_EL.hidden      = true;
    FEEDBACK_EL.textContent = '';
  }

  /* ────────────────────────────────────────────────────────
     EVENT LISTENERS
  ──────────────────────────────────────────────────────── */

  SECTION_EL.addEventListener('click', (e) => {
    const btn = e.target.closest('.custom-product-grid__hotspot');
    if (btn?.dataset.productUrl) openPopup(btn.dataset.productUrl);
  });

  CLOSE_BTN.addEventListener('click', closePopup);

  OVERLAY.addEventListener('click', (e) => {
    if (e.target === OVERLAY) closePopup();
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && OVERLAY.getAttribute('aria-hidden') === 'false') closePopup();
  });

  ATC_BTN.addEventListener('click', onAtcClick);

})();
</script>

