{%- comment %} Image URLs {%- endcomment %}
{%- assign bg_image        = section.settings.background_image -%}
{%- assign bg_image_mobile = section.settings.background_image_mobile -%}

<style>
  /* ── Section wrapper ── */
  .hero {
    position: relative;
    width: 100vw;
    left: 50%;
    margin-left: -50vw;
    min-height: {{ section.settings.banner_height }}vh;
    background-color: {{ section.settings.background_color }};
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  /* ── Desktop background image ── */
  .hero__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
  }

  /* Placeholder SVG */
  .hero__bg-placeholder {
    position: absolute;
    inset: 0;
    z-index: 0;
    width: 100%;
    height: 100%;
    display: block;
    opacity: 0.4;
  }

  /* ── Desktop content — bottom-left ── */
  .hero__content {
    position: relative;
    z-index: 2;
    margin-top: auto;
    padding: 0 0 42px 52px;
    max-width: 560px;
  }

  /* ── Mobile block — hidden on desktop ── */
  .hero__mobile {
    display: none;
  }

  /* ── Heading ── */
  .hero__heading {
    font-size: 70px;
    font-weight: 500;
    line-height: 1.0;
    color: {{ section.settings.heading_color }};
    margin: 0 0 28px;
    letter-spacing: 0;
  }

  /* ── Description ── */
  .hero__description {
    font-size: 20px;
    font-weight: 400;
    letter-spacing: 0;
    line-height: 1.4;
    color: {{ section.settings.description_color }};
    margin: 0 0 32px;
  }

  /* ── Button ── */
  .hero__btn {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 28px;
    background-color: {{ section.settings.primary_btn_bg }};
    color: {{ section.settings.primary_btn_color }};
    text-decoration: none;
    font-size: 16px;
    font-weight: 400;
    text-transform: uppercase;
    padding: 10.5px 36px;
    overflow: hidden;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }

  /* Button animation */
  .hero__btn::after {
    content: '';
    position: absolute;
    top: 0;
    left: -130%;
    width: 60%;
    height: 100%;
    background: linear-gradient(120deg, transparent 0%, rgba(255,255,255,0.28) 50%, transparent 100%);
    transform: skewX(-20deg);
    transition: left 0.55s ease;
    pointer-events: none;
  }

  .hero__btn:hover::after { left: 160%; }

  .hero__btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.22);
  }

  .hero__btn:active {
    transform: translateY(0);
    box-shadow: none;
  }

  /* Arrow slides right on hover */
  .hero__btn-arrow {
    display: inline-flex;
    align-items: center;
    transition: transform 0.25s ease;
  }

  .hero__btn-arrow img {
    display: block;
    width: auto;
    height: 14px;
  }

  .hero__btn:hover .hero__btn-arrow {
    transform: translateX(5px);
  }

  /* ── Strip ── */
  .hero__strip {
    position: relative;
    z-index: 2;
    width: 100%;
    background-color: {{ section.settings.ticker_bg }};
    padding: 4px 24px;
    text-align: center;
  }

  .hero__strip-text {
    font-size: 16px;
    font-weight: 400;
    letter-spacing: 0;
    line-height: 13.42px;
    text-transform: uppercase;
    color: {{ section.settings.ticker_color }};
  }

  /* ── MOBILE — ≤ 749px ── */
  @media (max-width: 749px) {
    .hero {
      min-height: unset;
      display: block;
    }

    /* Hide desktop bg image and content */
    .hero__bg,
    .hero__bg-placeholder,
    .hero__content {
      display: none;
    }

    /* Show mobile block */
    .hero__mobile {
      display: block;
    }

    /* Text block — centered at top */
    .hero__mobile-text {
      padding: 32px 24px 20px;
      text-align: center;
    }

    .hero__mobile-text .hero__heading {
      font-size: 30px;
      margin-bottom: 14px;
    }

    .hero__mobile-text .hero__description {
      font-size: 16px;
      max-width: 100%;
      margin-bottom: 0;
      color: #444;
    }

    /* Image wrapper — relative so button can sit on top */
    .hero__mobile-image {
      position: relative;
      width: 100%;
    }

    /* Mobile image / placeholder fills width */
    .hero__mobile-img,
    .hero__mobile-placeholder {
      width: 100%;
      height: 340px;
      display: block;
      object-fit: cover;
      object-position: center top;
    }

    /* Button — centered over bottom of image */
    .hero__btn--mobile {
      position: absolute;
      bottom: 14%;
      left: 50%;
      transform: translateX(-50%);
      white-space: nowrap;
      justify-content: center;
      padding: 9px 30px;
    }

    .hero__btn--mobile:hover {
      transform: translateX(-50%) translateY(-2px);
    }

    .hero__btn--mobile:active {
      transform: translateX(-50%) translateY(0);
    }

    .hero__strip-text {
      font-size: 14px;
    }
  }
</style>

<section
  id="hero"
  class="hero"
  aria-label="{{ section.settings.heading }}"
>

  {%- comment %}
    DESKTOP background — real <img> tag if image uploaded,
    otherwise Shopify placeholder SVG via placeholder_svg_tag.
    Both are absolutely positioned to cover the full section.
  {%- endcomment %}
  {%- if bg_image != blank -%}
    <img
      src="{{ bg_image | img_url: 'master' }}"
      alt=""
      class="hero__bg"
      loading="eager"
      aria-hidden="true"
    >
  {%- else -%}
    {{ 'hero-apparel-1' | placeholder_svg_tag: 'hero__bg-placeholder' }}
  {%- endif -%}

  {%- comment %} ── DESKTOP: bottom-left text content ── {%- endcomment %}
  <div class="hero__content">

    <h1 class="hero__heading">{{ section.settings.heading }}</h1>

    {%- if section.settings.description != blank -%}
      <p class="hero__description">{{ section.settings.description }}</p>
    {%- endif -%}

    {%- if section.settings.primary_button_label != blank -%}
      <a href="{{ section.settings.primary_button_url }}" class="hero__btn">
        <span class="hero__btn-label">{{ section.settings.primary_button_label }}</span>
        <span class="hero__btn-arrow" aria-hidden="true">
          <img src="https://cdn.shopify.com/s/files/1/0800/6208/7409/files/Line_15.svg?v=1780143098" alt="" aria-hidden="true">
        </span>
      </a>
    {%- endif -%}

  </div>

  {%- comment %} ── MOBILE ONLY — hidden on desktop via CSS ── {%- endcomment %}
  <div class="hero__mobile">

    {%- comment %} Text centered at top {%- endcomment %}
    <div class="hero__mobile-text">
      <h1 class="hero__heading">{{ section.settings.heading }}</h1>

      {%- assign mobile_desc = section.settings.description_mobile | default: section.settings.description -%}
      {%- if mobile_desc != blank -%}
        <p class="hero__description">{{ mobile_desc }}</p>
      {%- endif -%}
    </div>

    {%- comment %} MOBILE image wrapper {%- endcomment %}
    <div class="hero__mobile-image">

      {%- if bg_image_mobile != blank -%}
        <img
          src="{{ bg_image_mobile | img_url: 'master' }}"
          alt=""
          class="hero__mobile-img"
          loading="eager"
          aria-hidden="true"
        >
      {%- elsif bg_image != blank -%}
        <img
          src="{{ bg_image | img_url: 'master' }}"
          alt=""
          class="hero__mobile-img"
          loading="eager"
          aria-hidden="true"
        >
      {%- else -%}
        {{ 'hero-apparel-1' | placeholder_svg_tag: 'hero__mobile-placeholder' }}
      {%- endif -%}

      {%- if section.settings.primary_button_label != blank -%}
        <a href="{{ section.settings.primary_button_url }}" class="hero__btn hero__btn--mobile">
          <span class="hero__btn-label">{{ section.settings.primary_button_label }}</span>
          <span class="hero__btn-arrow" aria-hidden="true">
            <img src="https://cdn.shopify.com/s/files/1/0800/6208/7409/files/Line_15.svg?v=1780143098" alt="" aria-hidden="true">
          </span>
        </a>
      {%- endif -%}

    </div>

  </div>

  {%- comment %} ── Strip ── {%- endcomment %}
  {%- if section.settings.ticker_text != blank -%}
    <div class="hero__strip">
      <span class="hero__strip-text">{{ section.settings.ticker_text }}</span>
    </div>
  {%- endif -%}

</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "banner_height",
      "label": "Desktop min height (vh)",
      "min": 50,
      "max": 100,
      "step": 1,
      "unit": "vh",
      "default": 80
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background colour",
      "default": "#ffffff"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image (desktop)"
    },
    {
      "type": "image_picker",
      "id": "background_image_mobile",
      "label": "Background image (mobile)",
      "info": "Shown on screens ≤ 749px. Falls back to desktop image if left blank."
    },
    {
      "type": "header",
      "content": "Main Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The Gift Guide"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading colour",
      "default": "#000000"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description (desktop)",
      "info": "Full description shown on desktop",
      "default": "Discover Joy: Your Ultimate Holiday Gift Destination. Explore our curated selection and find the perfect gifts to delight your loved ones this holiday season."
    },
    {
      "type": "textarea",
      "id": "description_mobile",
      "label": "Description (mobile)",
      "info": "Shorter description shown on mobile. Leave blank to use desktop description.",
      "default": "Discover Joy: Your Ultimate Holiday Gift Destination."
    },
    {
      "type": "color",
      "id": "description_color",
      "label": "Description text colour",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "primary_button_label",
      "label": "Button label",
      "default": "SHOP NOW"
    },
    {
      "type": "url",
      "id": "primary_button_url",
      "label": "Button URL"
    },
    {
      "type": "color",
      "id": "primary_btn_bg",
      "label": "Button background",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "primary_btn_color",
      "label": "Button text colour",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Strip"
    },
    {
      "type": "text",
      "id": "ticker_text",
      "label": "Strip text",
      "default": "SUSTAINABLE, ETHICALLY MADE CLOTHES IN SIZES XXS TO 6XL"
    },
    {
      "type": "color",
      "id": "ticker_bg",
      "label": "Strip background",
      "default": "#F5F5F5"
    },
    {
      "type": "color",
      "id": "ticker_color",
      "label": "Strip text colour",
      "default": "#000000"
    }
  ],
  "presets": [
    {
      "name": "Hero"
    }
  ]
}
{% endschema %}
